# .env.example - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 命令: cp .env.example .env

# ====================
# 必须配置的变量
# ====================

# Gateway 认证令牌（用于 API 访问认证）
# 生成方法: openssl rand -hex 20
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ====================
# 模型 API 配置
# ====================

# volcengine (火山引擎 - 豆包/GLM) API Key
# 获取地址: https://console.volcengine.com/iam/keymanage
# 火山 Coding API Key（同时用于 Access Key 和 Secret Key）
OPENCLAW_VOLCENGINE_API_KEY=your_api_key

# 默认使用的主模型
# 支持的提供者: volcengine
# 可选值:
#   - volcengine-plan/glm-4.7 (推荐)
#   - volcengine-plan/doubao-seed-code
#   - volcengine-plan/deepseek-v3.2
OPENCLAW_MODEL_PRIMARY=volcengine-plan/glm-4.7

# ====================
# 可选配置
# ====================

# 飞书应用配置（从飞书开放平台获取）
# 如需使用飞书功能，请配置以下变量
# 1. 访问 https://open.feishu.cn/
# 2. 创建企业自建应用
# 3. 在"权限管理"中申请必要权限
# 4. 获取 App ID 和 App Secret
OPENCLAW_FEISHU_APP_ID=cli_your_app_id
OPENCLAW_FEISHU_APP_SECRET=your_app_secret

# 是否强制更新配置文件（容器启动时）
# 设置为 true 将在每次启动时重新生成配置文件
FORCE_CONFIG_UPDATE=false

# Gateway 端口（默认 18789）
# 容器内部端口映射到主机 18790，避免与本地 OpenClaw 冲突
GATEWAY_PORT=18789

# HPC 数据目录路径（可选）
# 用于挂载本地 HPC 数据目录到容器
# 示例: HPC_DATA_PATH=/path/to/your/hpc/data
HPC_DATA_PATH=./hpc-data
