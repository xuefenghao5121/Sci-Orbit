# .env.example - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 命令: cp .env.example .env

# ====================
# 必须配置的变量
# ====================

# Gateway 认证令牌（用于 API 访问认证）
# 生成方法: openssl rand -hex 20
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# 飞书应用配置（从飞书开放平台获取）
# 1. 访问 https://open.feishu.cn/
# 2. 创建企业自建应用
# 3. 在"权限管理"中申请必要权限
# 4. 获取 App ID 和 App Secret
OPENCLAW_FEISHU_APP_ID=cli_your_app_id
OPENCLAW_FEISHU_APP_SECRET=your_app_secret

# ====================
# 模型 API 配置
# ====================

# 智谱 AI (Z.ai) API Key
# 获取地址: https://open.bigmodel.cn/
OPENCLAW_ZAI_API_KEY=your-zai-api-key

# 百炼 API Key (阿里云)
# 获取地址: https://bailian.console.aliyun.com/
OPENCLAW_BAILIAN_API_KEY=your-bailian-api-key

# volcengine (火山引擎 - 豆包/GLM) API 凭证
# 获取地址: https://console.volcengine.com/iam/keymanage
OPENCLAW_VOLCENGINE_ACCESS_KEY=your_access_key
OPENCLAW_VOLCENGINE_SECRET_KEY=your_secret_key

# 默认使用的主模型
# 支持的提供者: zai | bailian | volcengine
# 可选值:
#   - zai: zai/glm-5, zai/glm-4.7
#   - bailian: bailian/qwen3.5-plus, bailian/qwen3-max-2026-01-23
#   - volcengine: volcengine-plan/glm-4.7, volcengine-plan/doubao-pro-32k
OPENCLAW_MODEL_PRIMARY=zai/glm-5

# ====================
# 可选配置
# ====================

# 是否强制更新配置文件（容器启动时）
# 设置为 true 将在每次启动时重新生成配置文件
FORCE_CONFIG_UPDATE=false

# Gateway 端口（默认 18789）
# 容器内部端口映射到主机 18790，避免与本地 OpenClaw 冲突
GATEWAY_PORT=18789

# HPC 数据目录路径（可选）
# 用于挂载本地 HPC 数据目录到容器
# 示例: HPC_DATA_PATH=/path/to/your/hpc/data
HPC_DATA_PATH=./hpc-data
