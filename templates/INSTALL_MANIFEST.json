    {
      "src": "skills/ai4s-learn/SKILL.md",
      "dst": "skills/ai4s-learn/SKILL.md",
      "description": "自动学习技能"
    },
    {
      "src": "skills/WORKFLOWS.md",
      "dst": "skills/WORKFLOWS.md",
      "description": "工作流串联文档"
    },
    {
      "src": "agents/ai4s-executor.md",
      "dst": "agents/ai4s-executor.md",
      "description": "执行者 Agent"
    },
    {
      "src": "agents/ai4s-deployer.md",
      "dst": "agents/ai4s-deployer.md",
      "description": "部署者 Agent"
    }
  ],
  "phase3_files": [
    {
      "src": "skills/ai4s-finetune/SKILL.md",
      "dst": "skills/ai4s-finetune/SKILL.md",
