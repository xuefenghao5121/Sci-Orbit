  "uninstall": {
    "files_to_remove": [
      "skills/ai4s-plan/SKILL.md",
      "skills/ai4s-status/SKILL.md",
      "skills/ai4s-debate/SKILL.md",
      "skills/ai4s-paper/SKILL.md",
      "skills/ai4s-exp/SKILL.md",
      "skills/ai4s-project/SKILL.md",
      "skills/ai4s-memory/SKILL.md",
      "skills/ai4s-env/SKILL.md",
      "skills/ai4s-learn/SKILL.md",
      "skills/WORKFLOWS.md",
      "agents/ai4s-planner.md",
      "agents/ai4s-reviewer.md",
      "agents/ai4s-executor.md",
      "agents/ai4s-deployer.md",
      "scripts/ai4s-env-inject.sh",
      "scripts/ai4s-numeric-check.sh"
    ],
    "files_to_clean": [
      "CLAUDE.md",
      "settings.json"
    ],
    "dirs_to_remove": [
      ".ai4s"
    ]
  }
