    {
      "src": "skills/ai4s-paper/SKILL.md",
      "dst": "skills/ai4s-paper/SKILL.md",
      "description": "论文工作流技能"
    },
    {
      "src": "skills/ai4s-exp/SKILL.md",
      "dst": "skills/ai4s-exp/SKILL.md",
      "description": "实验工作流技能"
    },
    {
      "src": "skills/ai4s-project/SKILL.md",
      "dst": "skills/ai4s-project/SKILL.md",
      "description": "项目管理技能"
    },
    {
      "src": "skills/ai4s-memory/SKILL.md",
      "dst": "skills/ai4s-memory/SKILL.md",
      "description": "记忆管理技能"
